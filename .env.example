# ============ AI Brain ============
ANTHROPIC_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here          # Free-tier fallback brain
GEMINI_MODEL=gemini-3.5-flash         # Must be an API model id (lowercase-with-dashes)
CLAUDE_MODEL=claude-sonnet-4-6          # Main model (as specified in the blueprint)

# ============ Google (Gmail + Calendar) ============
GOOGLE_CLIENT_ID=your_key_here
GOOGLE_CLIENT_SECRET=your_key_here
GOOGLE_REDIRECT_URI=http://localhost:8080

# ============ GitHub ============
GITHUB_TOKEN=your_key_here
GITHUB_USERNAME=your_username

# ============ Agent Identity ============
AGENT_NAME=Aria
AGENT_VOICE=en-US-AriaNeural            # Edge TTS voice
WAKE_WORD=hey aria

# ============ User Profile ============
USER_NAME=
USER_EMAIL=
USER_TIMEZONE=UTC
RESUME_PATH=./data/resume.pdf

# ============ Features ============
ENABLE_VOICE=true
ENABLE_COMPUTER_USE=true
ENABLE_WAKE_WORD=true

# ============ Morning Routine ============
MORNING_ROUTINE_TIME=08:00
ENABLE_MORNING_ROUTINE=true
